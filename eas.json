{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      }
    }
  },
  "updates": {
    "url": "https://u.expo.dev/your-project-id",
    "requestHeaders": {
      "expo-channel-name": "production"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  },
  "submit": {
    "production": {}
  }
}
