{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "gradleOptions": {
          "android.enableProguard": "true",
          "android.enableR8": "true"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
